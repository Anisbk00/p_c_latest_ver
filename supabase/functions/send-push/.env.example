# ═══════════════════════════════════════════════════════════════════════════════
# Supabase Edge Function Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# Set these in Supabase Dashboard:
# https://supabase.com/dashboard/project/ygzxxmyrybtvszjlilxg/settings/functions
#
# ─── APNs Configuration (for iOS Push Notifications) ──────────────────────────
#
# Get these from Apple Developer Portal:
# https://developer.apple.com/account/resources/authkeys/list
#
# APNS_KEY_ID=YOUR_KEY_ID          # e.g., ABC12DEF34
# APNS_TEAM_ID=YOUR_TEAM_ID        # e.g., ABC12DEF34
# APNS_BUNDLE_ID=com.yourapp.fit   # Your app's bundle identifier
# APNS_PRODUCTION=false            # true for production, false for sandbox
# APNS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_P8_KEY_CONTENT\n-----END PRIVATE KEY-----
#
# ─── Supabase Configuration (auto-set) ───────────────────────────────────────
#
# SUPABASE_URL=https://ygzxxmyrybtvszjlilxg.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
#
# ─── Alternative: Expo Push (for React Native apps) ───────────────────────────
#
# If using Expo, device tokens will start with "ExponentPushToken[...]"
# No additional configuration needed - Expo handles the push delivery
#
# ═══════════════════════════════════════════════════════════════════════════════
