# ═══════════════════════════════════════════════════════════════════════════
# PROGRESS COMPANION - ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ═══════════════════════════════════════════════════════════════════════════

# ── SUPABASE CONFIGURATION ─────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL=postgresql://postgres:your_password@db.your-project-ref.supabase.co:5432/postgres

# ── SUPABASE MANAGEMENT (for CLI operations) ───────────────────────────────
SUPABASE_ACCESS_TOKEN=your_supabase_access_token

# ── MOBILE BUILD CONFIGURATION ─────────────────────────────────────────────
NEXT_PUBLIC_MOBILE_BUILD=false
NEXT_PUBLIC_API_URL=https://your-deployed-backend.vercel.app

# ── AI SERVICES (REQUIRED for AI features) ─────────────────────────────────
# Google Gemini API Key - Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_AI_API_KEY=your_google_ai_key

# ── SECURITY SECRETS (Server-side only) ───────────────────────────────────
# AI Worker Protection - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AI_WORKER_SECRET=your_random_base64_secret

# Cron Job Protection - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CRON_SECRET=your_random_base64_secret

# Client-side Checksum Pepper - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXT_PUBLIC_CHECKSUM_SECRET=your_random_hex_secret

# ── OPTIONAL: AUTHENTICATION ───────────────────────────────────────────────
# NEXTAUTH_SECRET=your_nextauth_secret
# NEXTAUTH_URL=http://localhost:3000

# ── EXPO / EAS BUILD (for mobile) ──────────────────────────────────────────
EXPO_ACCESS_TOKEN=your_expo_access_token
